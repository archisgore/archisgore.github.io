source "https://rubygems.org"

# GitHub Pages mirrors a known-good gem set. Using github-pages keeps
# our local builds matching what GitHub Pages will deploy.
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end

# Performance shims that GitHub Pages assumes are installed.
gem "webrick", "~> 1.8"
